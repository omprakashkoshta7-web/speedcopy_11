{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_API_URL": "@vite_api_url",
    "VITE_RAZORPAY_KEY_ID": "@vite_razorpay_key_id",
    "VITE_TWILIO_VERIFY_SERVICE_SID": "@vite_twilio_verify_service_sid"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
