# ============================================================================
# SpeedCopy Client - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to git (it's in .gitignore)
# ============================================================================

# API Configuration
VITE_API_URL=https://product-202671058278.asia-south1.run.app
VITE_APP_NAME=SpeedCopy

# Razorpay Payment Gateway
# Get your key from: https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_test_YOUR_TEST_KEY_HERE

# Twilio Verify Service
VITE_TWILIO_VERIFY_SERVICE_SID=VAb0924bd6b4422558eff214e98882820

# Firebase Configuration (if using Firebase)
# Get these from Firebase Console: https://console.firebase.google.com
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Environment
NODE_ENV=development

# ============================================================================
# Setup Instructions:
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values
# 3. Restart dev server: npm run dev
# 4. Never commit .env to git
# ============================================================================
# API Configuration
# Leave empty for development to use Vite proxy
# Set to full URL for production (e.g., https://api.speedcopy.com)
# VITE_API_URL=http://localhost:4000

# App Configuration
VITE_APP_NAME=SpeedCopy
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_NOTIFICATIONS=true

# Razorpay Configuration
VITE_RAZORPAY_KEY_ID=rzp_test_6vdMK3ln1NsDMj


# Twilio Configuration (Phone OTP)
VITE_TWILIO_VERIFY_SERVICE_SID=VAb0924bd6b4422558eff214e98882820
 